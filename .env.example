# --- REQUIRED ---
# Supabase project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Supabase anon (publishable) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- RECOMMENDED ---
# Public site URL used to build canonical/OG URLs (defaults to https://uc4n.com)
NEXT_PUBLIC_SITE_URL=

# --- OPTIONAL: AI features ---
# Required only for /api/seo-autocomplete (the A.C.S.I button in the post editor)
GROQ_API_KEY=

# Declared in env.mjs but currently unused by route code:
TAVILY_API_KEY=
NEXT_PUBLIC_DEEPSEEK_API_KEY=
